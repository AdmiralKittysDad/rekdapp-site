<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password — REKD</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Barlow+Condensed:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #080808;
            --surface: #111111;
            --border: #1e1e1e;
            --accent: #c8fa5f;
            --accent-dim: rgba(200, 250, 95, 0.12);
            --text: #f0f0f0;
            --secondary: #666;
            --error: #ff4444;
            --mono: 'DM Mono', monospace;
            --display: 'Barlow Condensed', sans-serif;
        }

        html, body {
            height: 100%;
            background: var(--bg);
            color: var(--text);
            font-family: var(--mono);
            -webkit-font-smoothing: antialiased;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 24px;
        }

        /* Subtle grid background */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(200,250,95,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(200,250,95,0.03) 1px, transparent 1px);
            background-size: 48px 48px;
            pointer-events: none;
        }

        .container {
            width: 100%;
            max-width: 420px;
            position: relative;
            z-index: 1;
        }

        .wordmark {
            font-family: var(--display);
            font-weight: 700;
            font-size: 13px;
            letter-spacing: 0.3em;
            color: var(--accent);
            margin-bottom: 48px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .wordmark::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 40px;
        }

        .eyebrow {
            font-family: var(--mono);
            font-size: 10px;
            letter-spacing: 0.2em;
            color: var(--secondary);
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        h1 {
            font-family: var(--display);
            font-weight: 600;
            font-size: 36px;
            letter-spacing: 0.02em;
            line-height: 1;
            color: var(--text);
            margin-bottom: 32px;
            text-transform: uppercase;
        }

        .field {
            margin-bottom: 16px;
        }

        label {
            display: block;
            font-size: 10px;
            letter-spacing: 0.2em;
            color: var(--secondary);
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        input {
            width: 100%;
            background: var(--bg);
            border: 1px solid var(--border);
            color: var(--text);
            font-family: var(--mono);
            font-size: 14px;
            padding: 14px 16px;
            outline: none;
            transition: border-color 0.15s;
            -webkit-appearance: none;
            border-radius: 0;
        }

        input:focus {
            border-color: var(--accent);
        }

        input::placeholder {
            color: #333;
        }

        .strength-bar {
            height: 2px;
            background: var(--border);
            margin-top: 8px;
            overflow: hidden;
            display: none;
        }

        .strength-bar.visible { display: block; }

        .strength-fill {
            height: 100%;
            width: 0%;
            transition: width 0.3s, background-color 0.3s;
        }

        .strength-label {
            font-size: 10px;
            letter-spacing: 0.15em;
            color: var(--secondary);
            margin-top: 6px;
            min-height: 16px;
            text-transform: uppercase;
        }

        .error-msg {
            font-size: 11px;
            color: var(--error);
            margin-top: 6px;
            letter-spacing: 0.05em;
            min-height: 16px;
        }

        button {
            width: 100%;
            background: var(--accent);
            color: var(--bg);
            border: none;
            font-family: var(--display);
            font-weight: 700;
            font-size: 15px;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            padding: 18px;
            cursor: pointer;
            margin-top: 24px;
            transition: opacity 0.15s;
            position: relative;
            overflow: hidden;
        }

        button:hover { opacity: 0.9; }
        button:disabled { opacity: 0.4; cursor: not-allowed; }

        button .btn-text { transition: opacity 0.2s; }
        button .btn-loading {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.2s;
        }

        button.loading .btn-text { opacity: 0; }
        button.loading .btn-loading { opacity: 1; }

        .spinner {
            width: 18px;
            height: 18px;
            border: 2px solid rgba(0,0,0,0.3);
            border-top-color: var(--bg);
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        /* Success state */
        .success-state {
            display: none;
            text-align: center;
            padding: 16px 0;
        }

        .success-state.visible { display: block; }
        .form-state.hidden { display: none; }

        .success-icon {
            width: 48px;
            height: 48px;
            border: 2px solid var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
        }

        .success-icon svg {
            width: 20px;
            height: 20px;
            stroke: var(--accent);
            stroke-width: 2.5;
            fill: none;
        }

        .success-title {
            font-family: var(--display);
            font-weight: 600;
            font-size: 28px;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        .success-body {
            font-size: 13px;
            color: var(--secondary);
            line-height: 1.6;
            margin-bottom: 32px;
        }

        .open-app-btn {
            display: inline-block;
            background: transparent;
            border: 1px solid var(--accent);
            color: var(--accent);
            font-family: var(--display);
            font-weight: 600;
            font-size: 13px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            padding: 14px 32px;
            text-decoration: none;
            cursor: pointer;
            transition: background 0.15s, color 0.15s;
            width: 100%;
            text-align: center;
        }

        .open-app-btn:hover {
            background: var(--accent-dim);
        }

        /* Error state */
        .global-error {
            background: rgba(255,68,68,0.08);
            border: 1px solid rgba(255,68,68,0.3);
            padding: 14px 16px;
            font-size: 12px;
            color: var(--error);
            letter-spacing: 0.05em;
            margin-bottom: 20px;
            display: none;
        }

        .global-error.visible { display: block; }

        .footer {
            margin-top: 24px;
            font-size: 11px;
            color: #333;
            letter-spacing: 0.05em;
            text-align: center;
        }

        /* Animate in */
        .card {
            animation: fadeUp 0.4s ease both;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="wordmark">REKD</div>

        <div class="card">
            <!-- Form State -->
            <div class="form-state" id="formState">
                <div class="eyebrow">Account Security</div>
                <h1>New Password</h1>

                <div class="global-error" id="globalError"></div>

                <div class="field">
                    <label for="password">New Password</label>
                    <input
                        type="password"
                        id="password"
                        placeholder="Enter new password"
                        autocomplete="new-password"
                        oninput="checkStrength(this.value)"
                    >
                    <div class="strength-bar" id="strengthBar">
                        <div class="strength-fill" id="strengthFill"></div>
                    </div>
                    <div class="strength-label" id="strengthLabel"></div>
                </div>

                <div class="field">
                    <label for="confirm">Confirm Password</label>
                    <input
                        type="password"
                        id="confirm"
                        placeholder="Confirm new password"
                        autocomplete="new-password"
                    >
                    <div class="error-msg" id="matchError"></div>
                </div>

                <button id="submitBtn" onclick="handleSubmit()" disabled>
                    <span class="btn-text">Set New Password</span>
                    <span class="btn-loading"><div class="spinner"></div></span>
                </button>
            </div>

            <!-- Success State -->
            <div class="success-state" id="successState">
                <div class="success-icon">
                    <svg viewBox="0 0 24 24">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                </div>
                <div class="success-title">Password Updated</div>
                <div class="success-body">
                    Your password has been changed successfully.<br>
                    Return to REKD and sign in with your new password.
                </div>
                <a href="rekd://auth/callback" class="open-app-btn">Open REKD</a>
            </div>
        </div>

        <div class="footer">rekdapp.com &nbsp;·&nbsp; Your data stays yours</div>
    </div>

    <script>
        // Extract Supabase tokens from URL hash
        // Supabase sends: #access_token=...&refresh_token=...&type=recovery
        const hash = window.location.hash.substring(1)
        const params = new URLSearchParams(hash)
        const accessToken = params.get('access_token')
        const refreshToken = params.get('refresh_token')
        const type = params.get('type')

        // If no recovery token, show error immediately
        if (type !== 'recovery' || !accessToken) {
            document.getElementById('globalError').textContent = 'Invalid or expired reset link. Please request a new one from the REKD app.'
            document.getElementById('globalError').classList.add('visible')
            document.getElementById('submitBtn').disabled = true
        }

        function checkStrength(value) {
            const bar = document.getElementById('strengthBar')
            const fill = document.getElementById('strengthFill')
            const label = document.getElementById('strengthLabel')
            const btn = document.getElementById('submitBtn')

            bar.classList.add('visible')

            let score = 0
            if (value.length >= 8) score++
            if (value.length >= 12) score++
            if (/[A-Z]/.test(value)) score++
            if (/[0-9]/.test(value)) score++
            if (/[^A-Za-z0-9]/.test(value)) score++

            const levels = [
                { width: '20%', color: '#ff4444', text: 'Too short' },
                { width: '40%', color: '#ff8800', text: 'Weak' },
                { width: '60%', color: '#ffcc00', text: 'Fair' },
                { width: '80%', color: '#88cc00', text: 'Good' },
                { width: '100%', color: '#c8fa5f', text: 'Strong' },
            ]

            const level = levels[Math.min(score, 4)]
            fill.style.width = level.width
            fill.style.backgroundColor = level.color
            label.textContent = level.text
            label.style.color = level.color

            validateForm()
        }

        function validateForm() {
            const password = document.getElementById('password').value
            const confirm = document.getElementById('confirm').value
            const matchError = document.getElementById('matchError')
            const btn = document.getElementById('submitBtn')

            if (confirm.length > 0 && password !== confirm) {
                matchError.textContent = 'Passwords do not match'
                btn.disabled = true
                return false
            } else {
                matchError.textContent = ''
            }

            const valid = password.length >= 8 && (confirm === '' || password === confirm)
            btn.disabled = !(valid && password === confirm && confirm.length > 0)
            return valid && password === confirm
        }

        document.getElementById('confirm').addEventListener('input', validateForm)

        async function handleSubmit() {
            if (!validateForm()) return

            const password = document.getElementById('password').value
            const btn = document.getElementById('submitBtn')
            const globalError = document.getElementById('globalError')

            btn.classList.add('loading')
            btn.disabled = true
            globalError.classList.remove('visible')

            try {
                // Use Supabase REST API directly — no SDK needed
                // Step 1: Exchange recovery token to get a session
                const SUPABASE_URL = 'https://waamrvvqssxwbiutpouf.supabase.co'
                const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndhYW1ydnZxc3N4d2JpdXRwb3VmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI0MzY2ODEsImV4cCI6MjA4ODAxMjY4MX0.08QkmO7bB3iqqPPbUVt769u63D2s9zW9ZpF4ZGPIu4Q'

                // Update the user's password using the access token from the URL
                const response = await fetch(`${SUPABASE_URL}/auth/v1/user`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'apikey': SUPABASE_ANON_KEY,
                        'Authorization': `Bearer ${accessToken}`
                    },
                    body: JSON.stringify({ password: password })
                })

                if (!response.ok) {
                    const err = await response.json()
                    throw new Error(err.message || 'Password update failed')
                }

                // Success
                document.getElementById('formState').classList.add('hidden')
                document.getElementById('successState').classList.add('visible')

            } catch (error) {
                globalError.textContent = error.message || 'Something went wrong. Please try again.'
                globalError.classList.add('visible')
                btn.classList.remove('loading')
                btn.disabled = false
            }
        }
    </script>
</body>
</html>
